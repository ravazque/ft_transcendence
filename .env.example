# ═══════════════════════════════════════════════════════════════════════
# Environment variables — Template
# Copy this file to .env and fill in the values.
# Keep real secrets out of version control.
# ═══════════════════════════════════════════════════════════════════════

# ── PostgreSQL ──
POSTGRES_USER=transcendence_dev
POSTGRES_PASSWORD=transcendence_dev_password
POSTGRES_DB=transcendence_dev
DATABASE_URL=postgresql://transcendence_dev:transcendence_dev_password@db:5432/transcendence_dev

# ── Fullstack (Nuxt) ──
JWT_SECRET=dev_jwt_secret_cambiar_en_produccion
JWT_EXPIRATION=24h
NODE_ENV=development

# ── Nginx / WAF ──
NGINX_HTTPS_PORT=443
NGINX_HTTP_PORT=80
MODSEC_RULE_ENGINE=DetectionOnly
WAF_PARANOIA=1

# ── Directus CMS ──
DIRECTUS_SECRET=directus-dev-secret-change-in-production
DIRECTUS_ADMIN_EMAIL=admin@transcendence.local
DIRECTUS_ADMIN_PASSWORD=admin
DIRECTUS_PUBLIC_URL=https://localhost/cms
