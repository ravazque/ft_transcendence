# ═══════════════════════════════════════════════════════════════════════
# .gitignore
# ═══════════════════════════════════════════════════════════════════════

# ── Dependencies ──
node_modules/

# ── Build output ──
fullstack/.nuxt/
fullstack/.output/
fullstack/dist/

# ── Environment variables (contain secrets) ──
.env
.env.local
.env.*.local

# ── SSL certificates (generated locally, never commit private keys) ──
nginx/ssl/*.pem
nginx/ssl/*.key
nginx/ssl/*.crt

# ── IDE / Editor ──
.vscode/
.idea/
.claude/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db

# ── Logs ──
*.log
npm-debug.log*

# ── Prisma migrations (generated per developer) ──
fullstack/prisma/migrations/

# ── Local Docker overrides ──
docker-compose.override.yml

# ── Others ──
docs/private.md
