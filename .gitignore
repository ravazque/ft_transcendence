# ── Dependencies ──
node_modules/
.pnp
.pnp.js

# ── Build output ──
srcs/requirements/fullstack/.nuxt/
srcs/requirements/fullstack/.output/
srcs/requirements/fullstack/dist/
*.tsbuildinfo

# ── Test / coverage ──
coverage/
.nyc_output/
*.lcov

# ── Cache ──
.cache/
.parcel-cache/
.vite/
.eslintcache

# ── Environment variables (contain secrets) ──
srcs/.env
srcs/.env.local
srcs/.env.*.local
srcs/.env.production
srcs/.env.development

# ── SSL certificates (generated locally, never commit private keys) ──
srcs/requirements/nginx/ssl/*.pem
srcs/requirements/nginx/ssl/*.key
srcs/requirements/nginx/ssl/*.crt
srcs/requirements/nginx/ssl/*.csr

# ── IDE / Editor ──
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Local Docker overrides ──
srcs/docker-compose.override.yml

# ── Directus bind-mount directories ──
# Created on first boot by `make setup`. Contents (extensions, snapshots,
# uploads) are local to each developer and not part of the source tree.
srcs/requirements/directus/

# ── Prisma local dev artifacts ──
srcs/requirements/fullstack/prisma/dev.db
srcs/requirements/fullstack/prisma/dev.db-journal
